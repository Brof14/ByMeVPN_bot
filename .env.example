# ──────────────────────────────────────────────
# ByMeVPN Bot — environment variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789          # comma-separated list of admin Telegram IDs

# 3x-UI Panel
XUI_HOST=https://your-panel.example.com:2053
XUI_USERNAME=admin
XUI_PASSWORD=your_panel_password
INBOUND_ID=3                 # ID of the inbound in 3x-UI panel

# VLESS / Reality parameters
REALITY_HOST=your.server.ip.or.domain
REALITY_PORT=443
REALITY_SNI=www.microsoft.com
REALITY_FP=chrome
REALITY_PBK=your_public_key_here
REALITY_SID=                 # short ID, can be empty

# YooKassa (optional, leave empty to disable)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Referral bonus days
REF_BONUS_DAYS=3

# Support username
SUPPORT_USERNAME=@ByMeVPN_support
